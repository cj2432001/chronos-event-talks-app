# pyenv
#   For a library or app, you might want to share your .python-version.
#   Normally, this should be kept out of git.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a microservice that you deploy, you may want to ignore it.
#Pipfile.lock

# poetry
#   Similarly, OpenCoop recommends submitting poetry.lock to version control
#poetry.lock

# pdm
#   Similar to Pipfile.lock / poetry.lock, submit pdm.lock to version control
#pdm.lock
.pdm.toml
.pdm-plugins/

